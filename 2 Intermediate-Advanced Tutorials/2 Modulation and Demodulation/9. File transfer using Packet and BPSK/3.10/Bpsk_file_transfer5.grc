- name: snippet_0
  id: snippet
  parameters:
    alias: ''
    code: "with open(\"bpsk_transmit.txt\", \"w\") as f:\n    for val in range(0x30,\
      \ 0x3A):\n        payload = chr(val) * self.payload_size\n        f.write(payload)"
    comment: Create transmit file
    priority: '0'
    section: init_before_blocks
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [400, 132.0]
    rotation: 0
    state: enabled
- name: snippet_1
  id: snippet
  parameters:
    alias: ''
    code: "import filecmp\n\nif filecmp.cmp(\"bpsk_transmit.txt\", \"bpsk_receive.txt\"\
      , shallow=False):\n    print(\"Successful file transfer\")\nelse:\n   print(\"\
      Error: Transmit and Receive files differ\")"
    comment: Compare transmit and receive file
    priority: '0'
    section: main_after_stop
